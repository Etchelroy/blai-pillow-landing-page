        function updateInventoryDisplay() {
            document.querySelectorAll('.product-btn').forEach(btn => {
                const productName = btn.closest('.product-info').querySelector('.product-title').textContent;
                const stock = checkInventory(productName);
                
                if (stock === 0) {
                    btn.textContent = 'Out of Stock';
                    btn.disabled = true;
                    btn.style.backgroundColor = '#9CA3AF';
                } else if (stock < 5) {
