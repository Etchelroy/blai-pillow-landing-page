        // ==================== DYNAMIC DISCOUNT BANNER ==================== 
        function createDiscountBanner(discountPercent, expiresIn) {
            const banner = document.createElement('div');
            banner.setAttribute('class', 'discount-banner');
            banner.setAttribute('role', 'alert');
            banner.innerHTML = `
                <div class="banner-content">
                    <span class="banner-icon">챨혺혦혟</span>
                    <span class="banner-text">Get <strong>${discountPercent}% OFF</strong> on your first order! Use code: <strong>SLEEP${discountPercent}</strong></span>
                    <span class="banner-close">횄혰</span>
                </div>
                <div class="banner-timer" aria-label="Offer expires in ${expiresIn}">Expires in: <span id="discount-timer">${expiresIn}</span></div>
            `;

            document.body.insertBefore(banner, document.body.firstChild);

            banner.querySelector('.banner-close').addEventListener('click', () => {
                banner.remove();
                localStorage.setItem('discount-banner-dismissed', 'true');
            });

            // Countdown timer
            let timeLeft = parseInt(expiresIn);
            const timerInterval = setInterval(() => {
                timeLeft--;
                const hours = Math.floor(timeLeft / 60);
                const minutes = timeLeft % 60;
                document.getElementById('discount-timer').textContent = `${hours}h ${minutes}m`;

                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    banner.remove();
                }
            }, 60000); // Update every minute
        }

        // Show discount banner if not dismissed
        if (!localStorage.getItem('discount-banner-dismissed')) {
            createDiscountBanner(15, '24');
        }

